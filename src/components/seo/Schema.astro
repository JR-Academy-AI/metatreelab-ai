---
/**
 * JSON-LD injector. Accepts one schema object or an array of them and emits
 * one <script type="application/ld+json"> per object.
 *
 * set:html is intentional — we serialize a typed object ourselves, so the
 * payload is trusted and Astro's default escaping would corrupt the JSON.
 */
interface Props {
  data: object | Array<object | undefined | null | false>;
}

const { data } = Astro.props;
const items = (Array.isArray(data) ? data : [data]).filter(
  (d): d is object => Boolean(d) && typeof d === 'object',
);
---

{items.map((item) => (
  <script type="application/ld+json" set:html={JSON.stringify(item)} />
))}
