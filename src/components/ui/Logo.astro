---
interface Props {
  className?: string;
  showText?: boolean;
}

const { className = '' } = Astro.props;
---

<div class={`logo-group ${className}`} aria-label="Metatree AI Lab">
  <img
    src="/logo.png"
    alt="Metatree AI Lab"
    class="logo-img"
    width="300"
    height="97"
  />
</div>

<style>
  .logo-group {
    display: inline-flex;
    align-items: center;
    cursor: pointer;
    text-decoration: none;
  }

  .logo-img {
    height: 36px;
    width: auto;
    display: block;
    transition: transform 0.3s var(--ease-out);
  }

  .logo-group:hover .logo-img {
    transform: scale(1.05);
  }
</style>
