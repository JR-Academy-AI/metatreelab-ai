---
/**
 * NeuralNetwork — Winding organic paths with high-density firing synapses.
 * 
 * Redesign goals:
 * - Precise node placement on winding paths.
 * - "Firing synapse" effect with quick bursts and slow decay.
 * - Concentrated activity on the right side.
 */

const VB_WIDTH = 1600;
const VB_HEIGHT = 900;

let seed = 666;
function random() {
  const x = Math.sin(seed++) * 10000;
  return x - Math.floor(x);
}

/**
 * Enhanced winding path that also returns key coordinates for node placement
 */
function getWindingPathWithPoints(x1: number, y1: number, x2: number, y2: number, variance = 100) {
  const midX = x1 + (x2 - x1) * 0.45;
  const midY = y1 + (y2 - y1) * 0.5 + (random() - 0.5) * variance * 2.2;
  
  const cp1x = x1 + (midX - x1) * (0.3 + random() * 0.3);
  const cp1y = y1 + (random() - 0.5) * variance;
  const cp2x = midX - (midX - x1) * (0.3 + random() * 0.3);
  const cp2y = midY + (random() - 0.5) * variance;
  
  const cp3x = midX + (x2 - midX) * (0.3 + random() * 0.3);
  const cp3y = midY + (random() - 0.5) * variance;
  const cp4x = x2 - (x2 - midX) * (0.3 + random() * 0.3);
  const cp4y = y2 + (random() - 0.5) * variance;
  
  const d = `M ${x1} ${y1} C ${cp1x} ${cp1y}, ${cp2x} ${cp2y}, ${midX} ${midY} S ${cp4x} ${cp4y}, ${x2} ${y2}`;
  
  return { d, points: [{x: midX, y: midY}, {x: x2, y: y2}] };
}

const branches = [];
const pulses = [];
const backgroundFibers = [];
const synapses = []; // The "popping" nodes

// 1. Generate Primary Trunks
const trunkCount = 12;
for (let i = 0; i < trunkCount; i++) {
  const startX = -120;
  const startY = 420 + (i - trunkCount / 2) * 22 + (random() - 0.5) * 40;
  const endX = VB_WIDTH + 200;
  const endY = random() * VB_HEIGHT;
  
  const { d, points } = getWindingPathWithPoints(startX, startY, endX, endY, 150);
  branches.push({ d, width: 1.2, delay: i * 0.1 });
  
  // Add pulses
  pulses.push({ d, delay: random() * 10, duration: 6 + random() * 6, width: 2 });

  // Add nodes at path keypoints (mostly on the right)
  points.forEach(p => {
    if (p.x > 500) {
      synapses.push({ 
        x: p.x, y: p.y, 
        r: 1.5 + random() * 2, 
        delay: random() * 5, 
        dur: 3 + random() * 4,
        type: 'burst'
      });
    }
  });

  // 2. Secondary Branching
  for (let step = 1; step <= 6; step++) {
      const prog = step / 6;
      const prob = 0.2 + prog * 0.7;
      
      if (random() < prob) {
          const bSX = startX + (endX - startX) * (prog * 0.8);
          const bSY = startY + (endY - startY) * (prog * 0.8) + (random() - 0.5) * 60;
          const bEX = bSX + 300 + random() * 600;
          const bEY = bSY + (random() - 0.5) * 500;
          
          const { d: subD, points: subPoints } = getWindingPathWithPoints(bSX, bSY, bEX, bEY, 80);
          branches.push({ d: subD, width: 0.7, delay: random() * 4 });
          
          if (random() > 0.4) {
              pulses.push({ d: subD, delay: random() * 8, duration: 8 + random() * 5, width: 1.2 });
          }

          // Dense nodes on sub-branches
          subPoints.forEach(p => {
              if (p.x > 600) {
                synapses.push({ 
                  x: p.x, y: p.y, 
                  r: 1 + random() * 1.5, 
                  delay: random() * 8, 
                  dur: 4 + random() * 5,
                  type: random() > 0.5 ? 'burst' : 'twinkle'
                });
              }
          });
      }
  }
}

// 3. Extra Right-side Clusters
for (let j = 0; j < 30; j++) {
    synapses.push({
        x: 900 + random() * 600,
        y: random() * VB_HEIGHT,
        r: 0.8 + random() * 1.2,
        delay: random() * 10,
        dur: 5 + random() * 5,
        type: 'twinkle'
    });
}
---

<div class="neural-root" aria-hidden="true">
  <svg
    viewBox={`0 0 ${VB_WIDTH} ${VB_HEIGHT}`}
    xmlns="http://www.w3.org/2000/svg"
    preserveAspectRatio="xMidYMid slice"
    class="neural-svg"
  >
    <defs>
      <linearGradient id="pathGrad" x1="0%" y1="0%" x2="100%" y2="0%">
        <stop offset="0%" stop-color="var(--brand-primary)" stop-opacity="0" />
        <stop offset="45%" stop-color="var(--brand-primary)" stop-opacity="0.12" />
        <stop offset="85%" stop-color="var(--brand-secondary)" stop-opacity="0.18" />
        <stop offset="100%" stop-color="var(--brand-secondary)" stop-opacity="0" />
      </linearGradient>

      <radialGradient id="synapseGlow" cx="50%" cy="50%" r="50%">
        <stop offset="0%" stop-color="#FFFFFF" stop-opacity="0.8" />
        <stop offset="40%" stop-color="var(--brand-primary)" stop-opacity="0.4" />
        <stop offset="100%" stop-color="var(--brand-primary)" stop-opacity="0" />
      </radialGradient>

      <filter id="bloomEffect" x="-200%" y="-200%" width="500%" height="500%">
        <feGaussianBlur stdDeviation="3" result="blur" />
        <feComposite in="SourceGraphic" in2="blur" operator="over" />
      </filter>
    </defs>

    <!-- Winding Branches -->
    <g class="layer-branches">
      {branches.map((b) => (
        <path
          d={b.d}
          pathLength="100"
          fill="none"
          stroke="url(#pathGrad)"
          stroke-width={b.width}
          class="branch-draw"
          style={`animation-delay: ${b.delay}s`}
        />
      ))}
    </g>

    <!-- Data Signals -->
    <g class="layer-pulses" filter="url(#bloomEffect)">
      {pulses.map((p) => (
        <path
          d={p.d}
          pathLength="100"
          fill="none"
          stroke="var(--brand-primary)"
          stroke-width={p.width}
          stroke-linecap="round"
          class="pulse-flow"
          style={`animation-delay: ${p.delay}s; animation-duration: ${p.duration}s;`}
        />
      ))}
    </g>

    <!-- Firing Synapses (Neurons) -->
    <g class="layer-synapses" filter="url(#bloomEffect)">
      {synapses.map((s) => (
        <circle
          cx={s.x}
          cy={s.y}
          r={s.r}
          fill="url(#synapseGlow)"
          class={s.type === 'burst' ? 'synapse-burst' : 'synapse-twinkle'}
          style={`animation-delay: ${s.delay}s; animation-duration: ${s.dur}s;`}
        />
      ))}
    </g>
  </svg>
</div>

<style>
  .neural-root {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    will-change: transform;
    transform: translateZ(0);
    /* Focus density on right, protect text on left */
    mask-image: linear-gradient(to right, transparent 0%, transparent 30%, black 60%, black 90%, transparent 100%);
    -webkit-mask-image: linear-gradient(to right, transparent 0%, transparent 30%, black 60%, black 90%, transparent 100%);
    opacity: 0.85;
  }

  .neural-svg {
    width: 100%;
    height: 100%;
    overflow: visible;
  }

  .branch-draw {
    stroke-dasharray: 100;
    stroke-dashoffset: 100;
    animation: growPath 4s var(--ease-out) forwards;
  }

  .pulse-flow {
    opacity: 0;
    stroke-dasharray: 5 95;
    stroke-dashoffset: 100;
    animation: signalFlow linear infinite;
  }

  /* Burst: High-frequency flicker / signal firing */
  .synapse-burst {
    opacity: 0;
    transform-origin: center;
    animation: flashEffect ease-in-out infinite;
  }

  /* Twinkle: Soft background shimmer */
  .synapse-twinkle {
    opacity: 0;
    transform-origin: center;
    animation: shimmerEffect ease-in-out infinite;
  }

  @keyframes growPath {
    to { stroke-dashoffset: 0; }
  }

  @keyframes signalFlow {
    0% { stroke-dashoffset: 100; opacity: 0; }
    15% { opacity: 0.4; }
    50% { stroke-dasharray: 15 85; opacity: 0.4; }
    85% { opacity: 0; }
    100% { stroke-dashoffset: 0; opacity: 0; }
  }

  /* Neural firing: Multi-stage opacity flicker, very subtle scale */
  @keyframes flashEffect {
    0%, 100% { opacity: 0; transform: scale(0.9); }
    10% { opacity: 1; transform: scale(1.05); } /* Main strike */
    14% { opacity: 0.3; }
    18% { opacity: 0.8; } /* Micro-rebound strike */
    35% { opacity: 0; transform: scale(0.95); }
  }

  /* Subtle background twinkling */
  @keyframes shimmerEffect {
    0%, 100% { opacity: 0.05; transform: scale(1); }
    50% { opacity: 0.4; transform: scale(1.05); }
  }

  @media (prefers-reduced-motion: reduce) {
    .branch-draw, .pulse-flow, .synapse-burst, .synapse-twinkle {
      animation: none;
      opacity: 0.2;
    }
    .branch-draw { stroke-dashoffset: 0; }
  }
</style>
