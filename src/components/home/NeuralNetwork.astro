---
/**
 * NeuralNetwork — visibly layered, branching network that starts near the
 * text block and expands outward with denser tiers.
 */

const VB_WIDTH = 1280;
const VB_HEIGHT = 760;

type Node = {
  id: string;
  x: number;
  y: number;
  r: number;
  tierIdx: number;
  nodeIdx: number;
  pulseDelay: number;
};

type Tier = {
  x: number;
  ys: number[];
  nodeRadius: number;
};

const core: Node = {
  id: 'core',
  x: 360,
  y: 470,
  r: 8.8,
  tierIdx: -1,
  nodeIdx: 0,
  pulseDelay: 0,
};

const tiers: Tier[] = [
  { x: 470, ys: [410, 520], nodeRadius: 4.8 },
  { x: 610, ys: [330, 420, 520, 620], nodeRadius: 5.0 },
  { x: 780, ys: [246, 328, 412, 500, 588, 672], nodeRadius: 4.8 },
  { x: 962, ys: [178, 250, 324, 402, 484, 564, 640, 710], nodeRadius: 4.4 },
  { x: 1146, ys: [126, 190, 252, 318, 384, 452, 518, 584, 648, 714], nodeRadius: 4.0 },
];

const nodesByTier: Node[][] = tiers.map((tier, tierIdx) =>
  tier.ys.map((y, nodeIdx) => ({
    id: `tier-${tierIdx}-${nodeIdx}`,
    x: tier.x,
    y,
    r: tier.nodeRadius,
    tierIdx,
    nodeIdx,
    pulseDelay: (tierIdx * 0.42 + nodeIdx * 0.11) % 3.6,
  }))
);

type Connection = {
  id: string;
  d: string;
  delay: number;
  width: number;
};

const buildCurve = (from: Node, to: Node, arcA: number, arcB: number) => {
  const dx = to.x - from.x;
  const dy = to.y - from.y;
  const c1x = from.x + dx * 0.28;
  const c1y = from.y + dy * 0.1 + arcA;
  const c2x = from.x + dx * 0.76;
  const c2y = from.y + dy * 0.92 + arcB;
  return `M ${from.x} ${from.y} C ${c1x} ${c1y}, ${c2x} ${c2y}, ${to.x} ${to.y}`;
};

const connections: Connection[] = [];

nodesByTier[0].forEach((to, idx) => {
  connections.push({
    id: `core-${to.id}`,
    d: buildCurve(core, to, idx === 0 ? -38 : 34, idx === 0 ? -18 : 20),
    delay: idx * 0.24,
    width: 1.55,
  });
});

for (let tierIdx = 0; tierIdx < nodesByTier.length - 1; tierIdx++) {
  const fromTier = nodesByTier[tierIdx];
  const toTier = nodesByTier[tierIdx + 1];
  const ratio = toTier.length / fromTier.length;

  fromTier.forEach((from, fromIdx) => {
    const anchor = Math.round(fromIdx * ratio);
    const targets = [anchor - 1, anchor, anchor + 1, anchor + 2].filter(
      (targetIdx, idx, arr) =>
        targetIdx >= 0 && targetIdx < toTier.length && arr.indexOf(targetIdx) === idx
    );

    targets.forEach((targetIdx, localIdx) => {
      const to = toTier[targetIdx];
      const spread = localIdx - (targets.length - 1) / 2;
      const arcA = spread * 22 - 10 + tierIdx * 4;
      const arcB = spread * 18 + 8 - tierIdx * 2;
      connections.push({
        id: `${from.id}-${to.id}`,
        d: buildCurve(from, to, arcA, arcB),
        delay: (tierIdx * 0.84 + fromIdx * 0.09 + localIdx * 0.16) % 5.8,
        width: tierIdx < 2 ? 1.26 : 1.02,
      });
    });
  });
}

const allNodes = [core, ...nodesByTier.flat()];

const tierBands = [
  { x: 470, y: 468, rx: 84, ry: 152, delay: 0 },
  { x: 616, y: 476, rx: 122, ry: 224, delay: 0.5 },
  { x: 792, y: 472, rx: 146, ry: 292, delay: 1.1 },
  { x: 978, y: 456, rx: 158, ry: 336, delay: 1.7 },
  { x: 1142, y: 438, rx: 140, ry: 360, delay: 2.2 },
];
---

<div class="nn" aria-hidden="true">
  <div class="nn__mist nn__mist--a"></div>
  <div class="nn__mist nn__mist--b"></div>

  <svg
    viewBox={`0 0 ${VB_WIDTH} ${VB_HEIGHT}`}
    xmlns="http://www.w3.org/2000/svg"
    class="nn__svg"
  >
    <defs>
      <linearGradient id="nnEdgeStroke" x1="0%" y1="0%" x2="100%" y2="0%">
        <stop offset="0%" stop-color="#00E5A0" stop-opacity="0.1" />
        <stop offset="44%" stop-color="#7DF9C5" stop-opacity="0.34" />
        <stop offset="100%" stop-color="#00B4D8" stop-opacity="0.12" />
      </linearGradient>

      <linearGradient id="nnSignalStroke" x1="0%" y1="0%" x2="100%" y2="0%">
        <stop offset="0%" stop-color="#FFFFFF" stop-opacity="0" />
        <stop offset="30%" stop-color="#FFFFFF" stop-opacity="1" />
        <stop offset="65%" stop-color="#A5FFE4" stop-opacity="0.96" />
        <stop offset="100%" stop-color="#00B4D8" stop-opacity="0" />
      </linearGradient>

      <radialGradient id="nnNodeFill" cx="50%" cy="50%" r="72%">
        <stop offset="0%" stop-color="#FFFFFF" stop-opacity="1" />
        <stop offset="28%" stop-color="#D0FFF1" stop-opacity="0.98" />
        <stop offset="70%" stop-color="#00E5A0" stop-opacity="0.84" />
        <stop offset="100%" stop-color="#00B4D8" stop-opacity="0.2" />
      </radialGradient>

      <radialGradient id="nnHalo" cx="50%" cy="50%" r="50%">
        <stop offset="0%" stop-color="#00E5A0" stop-opacity="0.52" />
        <stop offset="60%" stop-color="#00B4D8" stop-opacity="0.15" />
        <stop offset="100%" stop-color="#00B4D8" stop-opacity="0" />
      </radialGradient>

      <filter id="nnGlow" x="-160%" y="-160%" width="420%" height="420%">
        <feGaussianBlur stdDeviation="4" result="blur" />
        <feMerge>
          <feMergeNode in="blur" />
          <feMergeNode in="SourceGraphic" />
        </feMerge>
      </filter>
    </defs>

    <g class="nn__bands">
      {
        tierBands.map((band) => (
          <ellipse
            cx={band.x}
            cy={band.y}
            rx={band.rx}
            ry={band.ry}
            class="nn__band"
            style={`animation-delay:${band.delay}s`}
          />
        ))
      }
    </g>

    <g class="nn__edges">
      {
        connections.map((connection) => (
          <path d={connection.d} class="nn__edge" stroke-width={connection.width} />
        ))
      }
    </g>

    <g class="nn__signals" filter="url(#nnGlow)">
      {
        connections.map((connection) => (
          <path
            d={connection.d}
            class="nn__signal"
            stroke-width={connection.width + 2}
            style={`animation-delay:${connection.delay}s`}
          />
        ))
      }
    </g>

    <g class="nn__halos" filter="url(#nnGlow)">
      {
        allNodes.map((node) => (
          <circle
            cx={node.x}
            cy={node.y}
            r={node.tierIdx === -1 ? 34 : node.r * 3.4}
            fill="url(#nnHalo)"
            class="nn__halo"
            style={`animation-delay:${node.pulseDelay}s`}
          />
        ))
      }
    </g>

    <g class="nn__nodes" filter="url(#nnGlow)">
      {
        allNodes.map((node) => (
          <circle
            cx={node.x}
            cy={node.y}
            r={node.r}
            fill="url(#nnNodeFill)"
            class:list={['nn__node', node.tierIdx === -1 && 'nn__node--core']}
            style={`animation-delay:${node.pulseDelay}s`}
          />
        ))
      }
    </g>

    <g class="nn__cores">
      {
        allNodes.map((node) => (
          <circle
            cx={node.x}
            cy={node.y}
            r={node.tierIdx === -1 ? 3.8 : Math.max(1.4, node.r * 0.34)}
            fill="#FFFFFF"
            class="nn__core"
            style={`animation-delay:${node.pulseDelay}s`}
          />
        ))
      }
    </g>
  </svg>
</div>

<style>
  .nn {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    isolation: isolate;
  }

  .nn__svg {
    position: relative;
    z-index: 2;
    width: 100%;
    height: 100%;
    display: block;
    overflow: visible;
  }

  .nn__mist {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 1;
    mix-blend-mode: screen;
    filter: blur(62px);
  }

  .nn__mist--a {
    inset: 34% 38% 10% 18%;
    background:
      radial-gradient(circle at 18% 58%, rgba(0, 229, 160, 0.18), transparent 18%),
      radial-gradient(circle at 48% 52%, rgba(125, 249, 197, 0.14), transparent 24%),
      radial-gradient(circle at 78% 44%, rgba(0, 180, 216, 0.1), transparent 22%);
    animation: nnMistA 10s ease-in-out infinite;
  }

  .nn__mist--b {
    inset: 8% 2% 0 48%;
    background:
      radial-gradient(circle at 28% 48%, rgba(0, 180, 216, 0.12), transparent 20%),
      radial-gradient(circle at 70% 34%, rgba(125, 249, 197, 0.1), transparent 18%);
    animation: nnMistB 14s ease-in-out infinite;
  }

  .nn__band {
    fill: none;
    stroke: rgba(125, 249, 197, 0.08);
    stroke-width: 1;
    stroke-dasharray: 8 15;
    opacity: 0.24;
    animation: nnBandPulse 6.4s ease-in-out infinite;
  }

  .nn__edge,
  .nn__signal {
    fill: none;
    stroke-linecap: round;
  }

  .nn__edge {
    stroke: url(#nnEdgeStroke);
    opacity: 0.92;
  }

  .nn__signal {
    stroke: url(#nnSignalStroke);
    stroke-dasharray: 1 240;
    opacity: 0;
    animation: nnSignalRun 4.7s linear infinite;
  }

  .nn__halo {
    opacity: 0.18;
    animation: nnHaloPulse 3.2s ease-in-out infinite;
  }

  .nn__node {
    opacity: 0.95;
    transform-origin: center;
    animation: nnNodePulse 3.2s ease-in-out infinite;
  }

  .nn__node--core {
    animation-duration: 2.6s;
  }

  .nn__core {
    opacity: 0.88;
    animation: nnCoreBlink 2.6s ease-in-out infinite;
  }

  @keyframes nnMistA {
    0%, 100% { transform: translate3d(0, 0, 0) scale(0.96); opacity: 0.62; }
    50% { transform: translate3d(0.6rem, -1rem, 0) scale(1.08); opacity: 0.96; }
  }

  @keyframes nnMistB {
    0%, 100% { transform: translate3d(0, 0, 0) scale(0.98); opacity: 0.45; }
    50% { transform: translate3d(-1rem, 0.5rem, 0) scale(1.05); opacity: 0.76; }
  }

  @keyframes nnBandPulse {
    0%, 100% { opacity: 0.14; stroke-dashoffset: 0; }
    50% { opacity: 0.36; stroke-dashoffset: -20; }
  }

  @keyframes nnSignalRun {
    0% {
      opacity: 0;
      stroke-dasharray: 1 240;
      stroke-dashoffset: 0;
    }
    10% { opacity: 1; }
    54% {
      opacity: 1;
      stroke-dasharray: 56 240;
    }
    100% {
      opacity: 0;
      stroke-dasharray: 1 240;
      stroke-dashoffset: -290;
    }
  }

  @keyframes nnHaloPulse {
    0%, 100% { opacity: 0.1; transform: scale(0.82); transform-origin: center; }
    50% { opacity: 0.32; transform: scale(1.22); }
  }

  @keyframes nnNodePulse {
    0%, 100% { opacity: 0.82; transform: scale(0.92); }
    50% { opacity: 1; transform: scale(1.14); }
  }

  @keyframes nnCoreBlink {
    0%, 100% { opacity: 0.72; }
    50% { opacity: 1; }
  }

  @media (max-width: 991px) {
    .nn__mist--a {
      inset: 34% 28% 12% 4%;
    }

    .nn__mist--b {
      inset: 10% -6% 0 42%;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .nn__mist,
    .nn__band,
    .nn__signal,
    .nn__halo,
    .nn__node,
    .nn__core {
      animation: none;
    }

    .nn__signal {
      opacity: 0.3;
      stroke-dasharray: none;
    }
  }
</style>
