---
import type { Locale } from '../../config/site';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;

const label = locale === 'zh' ? '关键数据' : 'BY THE NUMBERS';

const stats = locale === 'zh'
  ? [
      { value: '10+', unit: '', caption: '已交付 AI 项目' },
      { value: '50+', unit: '', caption: '服务过的企业客户' },
      { value: '5+', unit: '年', caption: 'AI 生产系统运维经验' },
      { value: '3', unit: '城', caption: '悉尼 · 墨尔本 · 阿德莱德' },
    ]
  : [
      { value: '10+', unit: '', caption: 'AI projects delivered' },
      { value: '50+', unit: '', caption: 'Enterprise clients served' },
      { value: '5+', unit: 'YRS', caption: 'Running AI in production' },
      { value: '3', unit: '', caption: 'Offices across Australia' },
    ];
---

<section class="stats">
  <div class="stats__inner container-x">
    <span class="section-label">/ 04 — {label}</span>

    <div class="stats__grid">
      {
        stats.map((s) => (
          <div class="stats__item">
            <div class="stats__value">
              {s.value}
              {s.unit && <span class="stats__unit">{s.unit}</span>}
            </div>
            <div class="stats__rule" aria-hidden="true"></div>
            <div class="stats__caption">{s.caption}</div>
          </div>
        ))
      }
    </div>
  </div>
</section>

<style>
  .stats {
    position: relative;
    padding-block: var(--space-8);
    z-index: 2;
  }

  .stats__inner {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }

  .stats__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-5);
  }

  .stats__item {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .stats__value {
    font-family: var(--font-sans);
    font-size: 9.6rem;
    font-weight: var(--fw-bold);
    line-height: 0.9;
    letter-spacing: -0.04em;
    color: var(--text-primary);
    display: flex;
    align-items: baseline;
    gap: var(--space-2);
  }

  .stats__unit {
    font-size: var(--fs-h4);
    font-family: var(--font-mono);
    font-weight: var(--fw-medium);
    letter-spacing: 0.04em;
    color: var(--text-tertiary);
    text-transform: uppercase;
  }

  .stats__rule {
    height: 1px;
    width: 100%;
    background: var(--border-hairline);
  }

  .stats__caption {
    font-family: var(--font-mono);
    font-size: var(--fs-body-sm);
    color: var(--text-tertiary);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    line-height: var(--lh-snug);
  }

  @media (max-width: 991px) {
    .stats__grid {
      grid-template-columns: repeat(2, 1fr);
      gap: var(--space-6) var(--space-5);
    }
    .stats__value {
      font-size: 7.2rem;
    }
  }

  @media (max-width: 480px) {
    .stats__grid {
      grid-template-columns: 1fr;
    }
  }
</style>
