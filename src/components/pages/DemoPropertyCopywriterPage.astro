<BaseLayout title={zh ? 'Demo · AI 地产文案生成' : 'Demo · AI Listing Copywriter'} description={description} locale={locale}>
  <PageHero sectionLabel={copy.sectionLabel} title={copy.title} subtitle={copy.subtitle} />

  <section class="pc">
    <div class="pc__inner container-x">
      <a href={hubHref} class="pc__back">{copy.backToHub}</a>

      <div class="pc__stage">
        <!-- LEFT: property card + controls -->
        <aside class="pc__left card-glass">
          <span class="pc__panel-tag">{copy.propLabel}</span>
          <div class="pc__chips" id="pc-prop-chips">
            {properties.map((p, i) => (
              <button class={`pc__chip${i === 0 ? ' is-on' : ''}`} type="button" data-prop={p.id}>{p.chip}</button>
            ))}
          </div>

          <div class="pc__card" id="pc-card">
            <div class="pc__photo" id="pc-photo" style={`background:${properties[0].gradient}`}>
              <span class="pc__photo-emoji" id="pc-photo-emoji">{properties[0].emoji}</span>
              <span class="pc__photo-tag">PHOTO</span>
            </div>
            <h3 class="pc__card-name" id="pc-card-name">{properties[0].name}</h3>
            <p class="pc__card-suburb" id="pc-card-suburb">📍 {properties[0].suburb}</p>
            <div class="pc__specs" id="pc-specs">
              <div class="pc__spec"><span class="pc__spec-k">{copy.specBeds}</span><span class="pc__spec-v" data-spec="beds">{properties[0].beds}</span></div>
              <div class="pc__spec"><span class="pc__spec-k">{copy.specBaths}</span><span class="pc__spec-v" data-spec="baths">{properties[0].baths}</span></div>
              <div class="pc__spec"><span class="pc__spec-k">{copy.specCar}</span><span class="pc__spec-v" data-spec="car">{properties[0].car}</span></div>
              <div class="pc__spec"><span class="pc__spec-k">{copy.specLand}</span><span class="pc__spec-v" data-spec="land">{properties[0].land}</span></div>
              <div class="pc__spec pc__spec--wide"><span class="pc__spec-k">{copy.specPrice}</span><span class="pc__spec-v" data-spec="price">{properties[0].price}</span></div>
            </div>
          </div>

          <div class="pc__tone">
            <span class="pc__tone-label">{copy.toneLabel}</span>
            <div class="pc__tone-toggle" id="pc-tone">
              <button class="pc__tone-btn is-on" type="button" data-tone="professional">{copy.toneProfessional}</button>
              <button class="pc__tone-btn" type="button" data-tone="warm">{copy.toneWarm}</button>
            </div>
          </div>
        </aside>

        <!-- RIGHT: output -->
        <div class="pc__app card-glass">
          <header class="pc__appbar">
            <div class="pc__appbar-left">
              <span class="pc__dot" aria-hidden="true"></span>
              <span class="pc__appname">{copy.appName}</span>
            </div>
            <button class="btn-primary pc__gen" id="pc-gen" type="button">{copy.generateBtn}</button>
          </header>

          <div class="pc__out" id="pc-out" aria-live="polite">
            <p class="pc__empty" id="pc-empty">{copy.emptyHint}</p>

            <div class="pc__writing" id="pc-writing" hidden>
              <span class="pc__writing-spark">✦</span>
              <span class="pc__writing-text">{copy.writing}</span>
              <span class="pc__dots"><i></i><i></i><i></i></span>
            </div>

            <div class="pc__blocks" id="pc-blocks"></div>
          </div>

          <footer class="pc__appfoot">
            <span class="pc__disclaimer">⚠︎ {copy.disclaimer}</span>
            <button class="pc__regen" id="pc-regen" type="button" hidden>{copy.regenerate}</button>
          </footer>
        </div>
      </div>

      <!-- Explainer -->
      <div class="pc__explain">
        <span class="section-label">{copy.explainLabel}</span>
        <h2 class="pc__explain-title">{copy.explainTitle}</h2>
        <ul class="pc__points">
          {copy.explainPoints.map((p) => <li>{p}</li>)}
        </ul>
        <div class="pc__try">
          <p>{copy.ctaTryYours}</p>
          <a href={contactHref} class="btn-primary">{copy.ctaBtn} →</a>
        </div>
      </div>
    </div>
  </section>

  <CtaFooter locale={locale} sectionNumber="03" />
</BaseLayout>

<script is:inline define:vars={{
  propertiesJson,
  channelsMeta,
  labels: {
    writing: copy.writing,
    generateBtn: copy.generateBtn,
    copyBtn: copy.copyBtn,
    copied: copy.copied,
  },
}}>
  function initPropertyCopywriter() {
    var stage = document.querySelector('.pc__stage');
    if (!stage || stage.getAttribute('data-init') === '1') return;
    stage.setAttribute('data-init', '1');

    var propChips = document.getElementById('pc-prop-chips');
    var toneToggle = document.getElementById('pc-tone');
    var genBtn = document.getElementById('pc-gen');
    var regenBtn = document.getElementById('pc-regen');
    var out = document.getElementById('pc-out');
    var empty = document.getElementById('pc-empty');
    var writing = document.getElementById('pc-writing');
    var blocks = document.getElementById('pc-blocks');
    var photo = document.getElementById('pc-photo');
    var photoEmoji = document.getElementById('pc-photo-emoji');
    var cardName = document.getElementById('pc-card-name');
    var cardSuburb = document.getElementById('pc-card-suburb');
    var specs = document.getElementById('pc-specs');
    if (!genBtn || !out || !blocks) return;

    var PROPS = JSON.parse(propertiesJson);
    var byId = {};
    PROPS.forEach(function (p) { byId[p.id] = p; });

    var CHANNELS = channelsMeta;
    var currentProp = PROPS[0].id;
    var currentTone = 'professional';
    var busy = false;
    var timers = [];

    function t(fn, ms) { timers.push(setTimeout(fn, ms)); }
    function clearTimers() { timers.forEach(clearTimeout); timers.length = 0; }

    function setSpec(name, val) {
      var el = specs ? specs.querySelector('[data-spec="' + name + '"]') : null;
      if (el) el.textContent = val;
    }

    function applyProperty(id) {
      var p = byId[id];
      if (!p) return;
      if (photo) photo.style.background = p.gradient;
      if (photoEmoji) photoEmoji.textContent = p.emoji;
      if (cardName) cardName.textContent = p.name;
      if (cardSuburb) cardSuburb.textContent = '📍 ' + p.suburb;
      setSpec('beds', p.beds);
      setSpec('baths', p.baths);
      setSpec('car', p.car);
      setSpec('land', p.land);
      setSpec('price', p.price);
    }

    function resetOutput() {
      clearTimers();
      busy = false;
      blocks.innerHTML = '';
      if (writing) writing.hidden = true;
      if (empty) empty.hidden = false;
      if (regenBtn) regenBtn.hidden = true;
      if (genBtn) { genBtn.disabled = false; genBtn.textContent = labels.generateBtn; }
    }

    function typeInto(el, text, done) {
      var i = 0;
      el.textContent = '';
      function step() {
        i += 2;
        el.textContent = text.slice(0, i);
        if (i < text.length) { t(step, 12); }
        else { el.textContent = text; if (done) done(); }
      }
      step();
    }

    function buildBlock(meta) {
      var block = document.createElement('div');
      block.className = 'pc__block';
      block.setAttribute('data-channel', meta.id);

      var head = document.createElement('div');
      head.className = 'pc__block-head';
      var label = document.createElement('span');
      label.className = 'pc__block-label';
      label.textContent = meta.icon + ' ' + meta.label;
      var copyBtn = document.createElement('button');
      copyBtn.className = 'pc__copy';
      copyBtn.type = 'button';
      copyBtn.textContent = '⧉ ' + labels.copyBtn;
      head.appendChild(label);
      head.appendChild(copyBtn);
      block.appendChild(head);

      var body = document.createElement('div');
      body.className = 'pc__block-body';
      block.appendChild(body);

      blocks.appendChild(block);
      t(function () { block.classList.add('is-in'); }, 20);
      return { block: block, body: body, copyBtn: copyBtn };
    }

    function wireCopy(copyBtn, getText) {
      copyBtn.addEventListener('click', function () {
        var text = getText();
        function flash() {
          copyBtn.textContent = '✓ ' + labels.copied;
          copyBtn.classList.add('is-copied');
          t(function () {
            copyBtn.textContent = '⧉ ' + labels.copyBtn;
            copyBtn.classList.remove('is-copied');
          }, 1400);
        }
        if (navigator.clipboard && navigator.clipboard.writeText) {
          navigator.clipboard.writeText(text).then(flash, flash);
        } else {
          flash();
        }
      });
    }

    function renderPoints(body, items) {
      var ul = document.createElement('ul');
      ul.className = 'pc__sell';
      body.appendChild(ul);
      var i = 0;
      function next() {
        if (i >= items.length) { return; }
        var li = document.createElement('li');
        li.textContent = items[i];
        ul.appendChild(li);
        t(function () { li.classList.add('is-in'); }, 20);
        i += 1;
        t(next, 220);
      }
      next();
    }

    function generate() {
      if (busy) return;
      busy = true;
      clearTimers();
      blocks.innerHTML = '';
      if (empty) empty.hidden = true;
      if (regenBtn) regenBtn.hidden = true;
      if (genBtn) { genBtn.disabled = true; genBtn.textContent = labels.writing; }
      if (writing) writing.hidden = false;

      var p = byId[currentProp];
      var voice = p.copy[currentTone];

      t(function () {
        if (writing) writing.hidden = true;
        var idx = 0;

        function runBlock() {
          if (idx >= CHANNELS.length) {
            busy = false;
            if (genBtn) { genBtn.disabled = false; genBtn.textContent = labels.regenerate; }
            if (regenBtn) regenBtn.hidden = true;
            return;
          }
          var meta = CHANNELS[idx];
          var parts = buildBlock(meta);

          if (meta.id === 'points') {
            wireCopy(parts.copyBtn, function () { return voice.points.join('\n'); });
            renderPoints(parts.body, voice.points);
            idx += 1;
            t(runBlock, 220 * voice.points.length + 320);
          } else {
            var text = voice[meta.id];
            wireCopy(parts.copyBtn, function () { return text; });
            var pre = document.createElement('div');
            pre.className = 'pc__block-text';
            parts.body.appendChild(pre);
            typeInto(pre, text, function () {
              idx += 1;
              t(runBlock, 280);
            });
          }
        }
        runBlock();
      }, 900);
    }

    // Show the finished example immediately (no typing) — visitors land on a result.
    function renderInstant() {
      clearTimers();
      busy = false;
      blocks.innerHTML = '';
      if (empty) empty.hidden = true;
      if (writing) writing.hidden = true;
      var p = byId[currentProp];
      var voice = p.copy[currentTone];
      CHANNELS.forEach(function (meta) {
        var parts = buildBlock(meta);
        parts.block.classList.add('is-in');
        if (meta.id === 'points') {
          wireCopy(parts.copyBtn, function () { return voice.points.join('\n'); });
          var ul = document.createElement('ul');
          ul.className = 'pc__sell';
          voice.points.forEach(function (it) {
            var li = document.createElement('li');
            li.textContent = it;
            li.classList.add('is-in');
            ul.appendChild(li);
          });
          parts.body.appendChild(ul);
        } else {
          var text = voice[meta.id];
          wireCopy(parts.copyBtn, function () { return text; });
          var pre = document.createElement('div');
          pre.className = 'pc__block-text';
          pre.textContent = text;
          parts.body.appendChild(pre);
        }
      });
      if (regenBtn) regenBtn.hidden = true;
      if (genBtn) { genBtn.disabled = false; genBtn.textContent = labels.regenerate; }
    }

    if (propChips) {
      propChips.addEventListener('click', function (e) {
        var btn = e.target.closest('.pc__chip');
        if (!btn || busy) return;
        var id = btn.getAttribute('data-prop');
        if (id === currentProp) return;
        currentProp = id;
        propChips.querySelectorAll('.pc__chip').forEach(function (c) { c.classList.remove('is-on'); });
        btn.classList.add('is-on');
        applyProperty(id);
        renderInstant();
      });
    }

    if (toneToggle) {
      toneToggle.addEventListener('click', function (e) {
        var btn = e.target.closest('.pc__tone-btn');
        if (!btn || busy) return;
        var tone = btn.getAttribute('data-tone');
        if (tone === currentTone) return;
        currentTone = tone;
        toneToggle.querySelectorAll('.pc__tone-btn').forEach(function (c) { c.classList.remove('is-on'); });
        btn.classList.add('is-on');
        // switch the example to the new voice immediately (no gating click)
        renderInstant();
      });
    }

    genBtn.addEventListener('click', generate);
    if (regenBtn) regenBtn.addEventListener('click', generate);

    // Land on the designed example, fully rendered — not an empty panel + button.
    applyProperty(currentProp);
    renderInstant();
  }

  initPropertyCopywriter();
  document.addEventListener('astro:after-swap', initPropertyCopywriter);
</script>

<style>
  .pc { padding-block: var(--space-7) var(--space-9); }

  .pc__back {
    display: inline-block; font-family: var(--font-mono); font-size: var(--fs-body-sm);
    color: var(--text-tertiary); margin-bottom: var(--space-4);
  }
  .pc__back:hover { color: var(--brand-primary); }

  .pc__stage {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-4);
    align-items: stretch;
  }

  /* ===== LEFT: property card + controls ===== */
  .pc__left {
    border-radius: var(--radius-lg);
    padding: var(--space-5);
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }
  .pc__panel-tag {
    font-family: var(--font-mono); font-size: var(--fs-micro);
    text-transform: uppercase; letter-spacing: 0.08em; color: var(--text-tertiary);
  }
  .pc__chips { display: flex; flex-wrap: wrap; gap: var(--space-2); }
  .pc__chip {
    font-family: var(--font-sans); font-size: var(--fs-body-sm); color: var(--text-primary);
    padding: var(--space-2) var(--space-3); border-radius: var(--radius-pill);
    background: var(--bg-base); border: 1px solid var(--border-hairline);
    cursor: pointer; transition: all var(--dur-fast) var(--ease-out);
  }
  .pc__chip:hover { border-color: var(--brand-primary); color: var(--brand-primary); transform: translateY(-1px); }
  .pc__chip.is-on {
    border-color: var(--brand-primary); color: var(--brand-primary);
    background: color-mix(in srgb, var(--brand-primary) 12%, transparent);
  }

  .pc__card {
    border-radius: var(--radius-md);
    border: 1px solid var(--border-hairline);
    background: var(--bg-base);
    padding: var(--space-3);
    display: flex; flex-direction: column; gap: var(--space-2);
  }
  .pc__photo {
    position: relative;
    height: 8.5rem;
    border-radius: var(--radius-sm);
    display: flex; align-items: center; justify-content: center;
    overflow: hidden;
    transition: background var(--dur-normal) var(--ease-out);
  }
  .pc__photo::after {
    content: '';
    position: absolute; inset: 0;
    background: radial-gradient(120% 80% at 50% 0%, rgba(255,255,255,0.12), transparent 60%);
    pointer-events: none;
  }
  .pc__photo-emoji { font-size: 3.4rem; line-height: 1; filter: drop-shadow(0 2px 10px rgba(0,0,0,0.35)); }
  .pc__photo-tag {
    position: absolute; top: 0.5rem; right: 0.6rem;
    font-family: var(--font-mono); font-size: var(--fs-micro); letter-spacing: 0.12em;
    color: rgba(255,255,255,0.8);
    background: rgba(0,0,0,0.35); border-radius: var(--radius-sm);
    padding: 0.1rem 0.45rem;
  }
  .pc__card-name {
    font-size: var(--fs-body-lg); font-weight: var(--fw-bold);
    color: var(--text-primary); margin: 0;
  }
  .pc__card-suburb { margin: 0; font-size: var(--fs-body-sm); color: var(--text-secondary); }

  .pc__specs {
    display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-2);
    margin-top: var(--space-1);
  }
  .pc__spec {
    display: flex; flex-direction: column; gap: 0.15rem;
    padding: var(--space-2);
    border-radius: var(--radius-sm);
    background: var(--bg-elevated);
    border: 1px solid var(--border-hairline);
  }
  .pc__spec--wide { grid-column: 1 / -1; }
  .pc__spec-k {
    font-family: var(--font-mono); font-size: var(--fs-micro);
    text-transform: uppercase; letter-spacing: 0.05em; color: var(--text-tertiary);
  }
  .pc__spec-v { font-size: var(--fs-body-sm); font-weight: var(--fw-semibold); color: var(--text-primary); }

  .pc__tone { display: flex; flex-direction: column; gap: var(--space-2); }
  .pc__tone-label {
    font-family: var(--font-mono); font-size: var(--fs-micro);
    text-transform: uppercase; letter-spacing: 0.08em; color: var(--text-tertiary);
  }
  .pc__tone-toggle {
    display: inline-flex; padding: 0.25rem; gap: 0.25rem;
    border-radius: var(--radius-pill); border: 1px solid var(--border-hairline);
    background: var(--bg-base); width: fit-content;
  }
  .pc__tone-btn {
    font-family: var(--font-sans); font-size: var(--fs-body-sm); color: var(--text-secondary);
    padding: var(--space-2) var(--space-4); border-radius: var(--radius-pill);
    background: none; border: none; cursor: pointer;
    transition: all var(--dur-fast) var(--ease-out);
  }
  .pc__tone-btn:hover { color: var(--text-primary); }
  .pc__tone-btn.is-on {
    color: var(--bg-base);
    background: var(--brand-gradient);
    font-weight: var(--fw-semibold);
  }

  /* ===== RIGHT: output app ===== */
  .pc__app { border-radius: var(--radius-lg); overflow: hidden; display: flex; flex-direction: column; }
  .pc__appbar {
    display: flex; align-items: center; justify-content: space-between; gap: var(--space-3);
    padding: var(--space-3) var(--space-4);
    border-bottom: 1px solid var(--border-hairline); background: var(--bg-elevated);
  }
  .pc__appbar-left { display: flex; align-items: center; gap: var(--space-2); }
  .pc__dot { width: 0.8rem; height: 0.8rem; border-radius: 50%; background: var(--brand-primary); box-shadow: 0 0 8px var(--brand-primary); }
  .pc__appname { font-weight: var(--fw-semibold); color: var(--text-primary); font-size: var(--fs-body-sm); }
  .pc__gen { white-space: nowrap; }

  .pc__out {
    flex: 1; min-height: 22rem; max-height: 46rem; overflow-y: auto;
    padding: var(--space-4);
    display: flex; flex-direction: column; gap: var(--space-3);
  }
  .pc__empty { color: var(--text-tertiary); font-size: var(--fs-body-sm); line-height: 1.6; margin: 0; }

  .pc__writing {
    display: inline-flex; align-items: center; gap: var(--space-2);
    font-family: var(--font-mono); font-size: var(--fs-body-sm); color: var(--brand-primary);
  }
  .pc__writing-spark { display: inline-block; animation: pc-spin 1.4s linear infinite; }
  .pc__dots i {
    display: inline-block; width: 0.4rem; height: 0.4rem; margin-left: 0.2rem;
    border-radius: 50%; background: var(--brand-primary);
    animation: pc-blink 1.2s infinite ease-in-out;
  }
  .pc__dots i:nth-child(2) { animation-delay: 0.2s; }
  .pc__dots i:nth-child(3) { animation-delay: 0.4s; }

  .pc__blocks { display: flex; flex-direction: column; gap: var(--space-3); }
  .pc__block {
    border-radius: var(--radius-md);
    border: 1px solid var(--border-hairline);
    background: var(--bg-base);
    overflow: hidden;
    opacity: 0; transform: translateY(6px);
    transition: opacity var(--dur-normal) var(--ease-out), transform var(--dur-normal) var(--ease-out);
  }
  .pc__block.is-in { opacity: 1; transform: none; }
  .pc__block[data-channel="red"] { border-left: 3px solid #ff4d6d; }
  .pc__block[data-channel="wechat"] { border-left: 3px solid #07c160; }
  .pc__block[data-channel="listing"] { border-left: 3px solid var(--brand-secondary); }
  .pc__block[data-channel="points"] { border-left: 3px solid var(--brand-primary); }

  .pc__block-head {
    display: flex; align-items: center; justify-content: space-between; gap: var(--space-2);
    padding: var(--space-2) var(--space-3);
    border-bottom: 1px solid var(--border-hairline);
    background: var(--bg-elevated);
  }
  .pc__block-label { font-size: var(--fs-body-sm); font-weight: var(--fw-semibold); color: var(--text-primary); }
  .pc__copy {
    font-family: var(--font-mono); font-size: var(--fs-micro); color: var(--text-tertiary);
    background: none; border: 1px solid var(--border-hairline); border-radius: var(--radius-sm);
    padding: 0.2rem 0.55rem; cursor: pointer;
    transition: all var(--dur-fast) var(--ease-out);
  }
  .pc__copy:hover { border-color: var(--brand-primary); color: var(--brand-primary); }
  .pc__copy.is-copied { border-color: var(--brand-primary); color: var(--brand-primary); }

  .pc__block-body { padding: var(--space-3); }
  .pc__block-text {
    font-size: var(--fs-body); line-height: 1.6; color: var(--text-primary);
    white-space: pre-wrap;
  }

  .pc__sell { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: var(--space-2); }
  .pc__sell li {
    position: relative; padding-left: var(--space-5);
    font-size: var(--fs-body); line-height: 1.5; color: var(--text-secondary);
    opacity: 0; transform: translateX(-4px);
    transition: opacity var(--dur-normal) var(--ease-out), transform var(--dur-normal) var(--ease-out);
  }
  .pc__sell li.is-in { opacity: 1; transform: none; }
  .pc__sell li::before {
    content: '✓'; position: absolute; left: 0; color: var(--brand-primary); font-weight: var(--fw-bold);
  }

  .pc__appfoot {
    display: flex; align-items: center; justify-content: space-between; gap: var(--space-3);
    padding: var(--space-3) var(--space-4); border-top: 1px solid var(--border-hairline);
  }
  .pc__disclaimer { font-family: var(--font-mono); font-size: var(--fs-micro); color: var(--text-muted); }
  .pc__regen { font-family: var(--font-mono); font-size: var(--fs-body-sm); color: var(--text-secondary); background: none; border: none; cursor: pointer; }
  .pc__regen:hover { color: var(--brand-primary); }

  /* ===== Explainer ===== */
  .pc__explain { max-width: 64rem; margin-top: var(--space-7); }
  .pc__explain-title {
    font-size: var(--fs-h3); font-weight: var(--fw-bold); letter-spacing: -0.02em;
    color: var(--text-primary); margin: var(--space-2) 0 var(--space-4);
  }
  .pc__points { list-style: none; padding: 0; margin: 0; display: grid; gap: var(--space-3); }
  .pc__points li {
    position: relative; padding-left: var(--space-5);
    color: var(--text-secondary); font-size: var(--fs-body); line-height: 1.55;
  }
  .pc__points li::before { content: '✓'; position: absolute; left: 0; color: var(--brand-primary); font-weight: var(--fw-bold); }
  .pc__try {
    display: flex; flex-wrap: wrap; align-items: center; gap: var(--space-4);
    margin-top: var(--space-6); padding: var(--space-5);
    border-radius: var(--radius-md); background: var(--bg-glass); border: 1px solid var(--border-hairline);
  }
  .pc__try p { margin: 0; font-size: var(--fs-body-lg); font-weight: var(--fw-semibold); color: var(--text-primary); }

  /* ===== Keyframes ===== */
  @keyframes pc-spin { from { transform: rotate(0); } to { transform: rotate(360deg); } }
  @keyframes pc-blink { 0%, 100% { opacity: 0.3; transform: translateY(0); } 50% { opacity: 1; transform: translateY(-2px); } }

  /* ===== Responsive ===== */
  @media (max-width: 899px) {
    .pc__stage { grid-template-columns: 1fr; }
  }
  @media (max-width: 767px) {
    .pc__appbar { flex-wrap: wrap; }
