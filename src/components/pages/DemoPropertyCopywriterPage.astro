const properties = propsRaw.map((p) => ({
  id: p.id,
  emoji: p.emoji,
  gradient: p.gradient,
  name: p.name[locale],
  chip: p.chip[locale],
  suburb: p.suburb[locale],
  beds: p.beds,
  baths: p.baths,
  car: p.car,
  land: p.land[locale],
  price: p.price[locale],
  copy: {
    professional: {
      listing: p.copy.professional.listing[locale],
      red: p.copy.professional.red[locale],
      wechat: p.copy.professional.wechat[locale],
      points: p.copy.professional.points[locale],
    },
    warm: {
      listing: p.copy.warm.listing[locale],
      red: p.copy.warm.red[locale],
      wechat: p.copy.warm.wechat[locale],
      points: p.copy.warm.points[locale],
    },
  },
}));

const propertiesJson = JSON.stringify(properties);
const channelsMeta = channelOrder.map((id) => ({ id, icon: copy.channels[id].icon, label: copy.channels[id].label }));

const contactHref = localizedHref('/contact/', locale);
const hubHref = localizedHref('/demo/', locale);

const description = zh
  ? '在线体验 AI 地产文案生成：选房源、选语气，一键生成挂牌描述、小红书帖、朋友圈短文和卖点清单。模拟演示。'
  : 'Try an AI listing copywriter: pick a property and tone to generate a listing, a RED post, a WeChat blurb and selling points in one click. Simulated demo.';
