---
import BaseLayout from '../../layouts/BaseLayout.astro';
import HeroPlaceholder from '../../components/home/HeroPlaceholder.astro';
import ServiceSplit from '../../components/home/ServiceSplit.astro';
import PriceCompare from '../../components/home/PriceCompare.astro';
import SocialProof from '../../components/home/SocialProof.astro';
import WhyUs from '../../components/home/WhyUs.astro';
import EngagementModes from '../../components/home/EngagementModes.astro';
import TrustBar from '../../components/home/TrustBar.astro';
import StatsRow from '../../components/home/StatsRow.astro';
import FeaturedWork from '../../components/home/FeaturedWork.astro';
import CtaFooter from '../../components/shared/CtaFooter.astro';
import { siteConfig } from '../../config/site';
import { services } from '../../data/services';
import { featuredProjects } from '../../data/projects';
import { buildItemList, buildService, buildCreativeWork } from '../../lib/schema';

const flagshipServices = services.filter((s) => s.flagship);
const homeFeaturedProjects = featuredProjects.slice(0, 6);

const homeSchema = [
  buildItemList(
    '精选服务 — Metatree AI Lab',
    flagshipServices,
    (s) => buildService(s, 'zh'),
  ),
  buildItemList(
    '精选案例 — Metatree AI Lab',
    homeFeaturedProjects,
    (p) => buildCreativeWork(p, 'zh'),
  ),
];
---

<BaseLayout
  title={siteConfig.name}
  description={siteConfig.description.zh}
  locale="zh"
  path="/zh/"
  schema={homeSchema}
>
  <HeroPlaceholder locale="zh" />
  <ServiceSplit locale="zh" />
  <PriceCompare locale="zh" />
  <SocialProof locale="zh" />
  <WhyUs locale="zh" />
  <EngagementModes locale="zh" />
  <TrustBar locale="zh" />
  <StatsRow locale="zh" />
  <FeaturedWork locale="zh" />
  <CtaFooter locale="zh" />
</BaseLayout>
